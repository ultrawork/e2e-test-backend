# === Infrastructure ===

# Public URL for web application
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Base URL for API used by mobile apps (iOS/Android)
API_BASE_URL=http://localhost:3000/api

# Backend API URL for Next.js web client
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Port number for Express.js backend server
PORT=3000

# Node.js environment (development/production)
NODE_ENV=development

# VPS server IP address or domain for deployment
VPS_HOST=

# SSH username for VPS deployment
VPS_USER=

# === Credentials (keep secret!) ===

# Private SSH key for VPS deployment
VPS_SSH_KEY=

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notes

# Secret key for signing JWT tokens
JWT_SECRET=

# Enable JWT authentication (true/false). When false, uses default dev user.
JWT_ENABLED=true

# Allowed CORS origins (comma-separated). Use * to allow all origins.
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Default user ID for dev-token endpoint (only used in development mode)
DEV_USER_ID=dev-user-id
